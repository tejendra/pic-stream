# Backend environment – copy to .env and set real values. Do not commit .env.

# Required for album tokens (min 32 chars). Used by auth middleware (later work items).
JWT_SECRET=your-jwt-secret-min-32-chars

# Required for cron/delete-expired endpoint. Send as Authorization: Bearer <CRON_SECRET>.
CRON_SECRET=your-cron-secret

# Firebase. Backend defaults to project in .firebaserc if unset; override for another project.
GOOGLE_CLOUD_PROJECT=your-project-id
FIREBASE_STORAGE_BUCKET=your-project-id.appspot.com
