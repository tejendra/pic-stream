# Backend environment – copy to .env and set values for local dev.
# Do not commit .env (secrets).

PORT=3001
CORS_ORIGIN=http://localhost:5173

# Firebase: backend defaults to project in .firebaserc. Override only if using a different project:
# GOOGLE_CLOUD_PROJECT=other-project-id
# FIREBASE_STORAGE_BUCKET=other-project.firebasestorage.app
# Local dev auth (optional): path to service account JSON.
# GOOGLE_APPLICATION_CREDENTIALS=path/to/service-account.json
